name = "ouoankang/moonformdata"

version = "0.1.0"

readme = "README.md"

repository = "https://github.com/ouoankang/moonformdata"

license = "Apache-2.0"

keywords = [ "multipart", "form-data", "http", "upload", "parser" ]

preferred_target = "wasm-gc"

description = "MoonBit native multipart/form-data parser and encoder for file upload, webhook, and HTTP tooling."
